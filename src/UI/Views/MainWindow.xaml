<Window x:Class="ScanPro.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ScanPro.UI.ViewModels"
        Title="ScanPro - Belge Tarayici"
        Width="1300" Height="840"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#0C0D10"
        Foreground="#DDE1EC">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- TOOLBAR -->
        <Border Grid.Row="0" Background="#111318" BorderBrush="#1AFFFFFF" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                <Button Content="  Yeni Tarama  " Command="{Binding ScanCommand}"
                        Background="#2F80ED" Foreground="White" BorderThickness="0"
                        Padding="0,8" Margin="0,0,8,0" Cursor="Hand" FontSize="13" FontWeight="SemiBold"/>
                <Button Content="  Tarayici Yenile  " Command="{Binding FindScannersCommand}"
                        Background="#1E2030" Foreground="#8B91A4" BorderThickness="0"
                        Padding="0,8" Margin="0,0,8,0" Cursor="Hand"/>
                <Button Content="  Disa Aktar  " Command="{Binding ExportCommand}"
                        Background="#1E2030" Foreground="#8B91A4" BorderThickness="0"
                        Padding="0,8" Cursor="Hand"/>
                <Button Content="  Iptal  " Command="{Binding CancelCommand}"
                        Background="#3a1a1a" Foreground="#FF6B6B" BorderThickness="0"
                        Padding="0,8" Margin="8,0,0,0" Cursor="Hand"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"/>
            </StackPanel>
        </Border>

        <!-- MAIN -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="290"/>
            </Grid.ColumnDefinitions>

            <!-- SOL PANEL -->
            <Border Background="#0F1116" BorderBrush="#1AFFFFFF" BorderThickness="0,0,1,0">
                <StackPanel Margin="10,16">
                    <TextBlock Text="MENU" Foreground="#444" FontSize="9" FontWeight="Bold" Margin="6,0,0,8"/>
                    <Border Background="#182F80ED" CornerRadius="7" Padding="10,8" Margin="0,1">
                        <TextBlock Text="Genel Bakis" Foreground="#2F80ED" FontSize="12"/>
                    </Border>
                    <Border CornerRadius="7" Padding="10,8" Margin="0,1">
                        <TextBlock Text="Tarayici" Foreground="#8B91A4" FontSize="12"/>
                    </Border>
                    <Border CornerRadius="7" Padding="10,8" Margin="0,1">
                        <TextBlock Text="Toplu Is" Foreground="#8B91A4" FontSize="12"/>
                    </Border>
                    <Border CornerRadius="7" Padding="10,8" Margin="0,1">
                        <TextBlock Text="YZ Sinifla" Foreground="#8B91A4" FontSize="12"/>
                    </Border>
                    <Border Margin="0,24,0,0" Background="#0A27AE60" BorderBrush="#2527AE60"
                            BorderThickness="1" CornerRadius="8" Padding="10,10">
                        <StackPanel>
                            <TextBlock Text="Gizlilik Korumali" Foreground="#27AE60"
                                       FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="Cevrimdisi - Veri Saklanmaz"
                                       Foreground="#27AE60" FontSize="10" Margin="0,3,0,0" Opacity="0.8"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ORTA - PREVIEW -->
            <Grid Grid.Column="1" Background="#0C0D10" ClipToBounds="True">
                <!-- Bos durum -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasDocument}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Tarama baslatmak icin" Foreground="#444" FontSize="14"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Yeni Tarama butonuna tiklayin" Foreground="#333"
                               FontSize="12" HorizontalAlignment="Center" Margin="0,6,0,20"/>
                    <Button Content="  Yeni Tarama Baslat  " Command="{Binding ScanCommand}"
                            Background="#2F80ED" Foreground="White" BorderThickness="0"
                            Padding="0,10" HorizontalAlignment="Center" Cursor="Hand"
                            FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Yukleniyor -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="White"
                               FontSize="16" HorizontalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Width="300" Height="4"
                                 Margin="0,16,0,0" Foreground="#2F80ED" Background="#222"/>
                </StackPanel>

                <!-- Belge onizleme -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasDocument}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <Border HorizontalAlignment="Center" Width="460" Background="White"
                            CornerRadius="4">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="24" ShadowDepth="6"
                                              Direction="270" Color="Black" Opacity="0.5"/>
                        </Border.Effect>
                        <Grid>
                            <!-- Ust bilgi -->
                            <Border Height="26" VerticalAlignment="Top"
                                    Background="#1A3A6E" CornerRadius="4,4,0,0">
                                <Grid Margin="12,0">
                                    <TextBlock Text="{Binding HeaderLeft}" Foreground="#DDFFFFFF"
                                               FontSize="8" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding HeaderCenter}" Foreground="#DDFFFFFF"
                                               FontSize="8" HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding HeaderRight}" Foreground="#DDFFFFFF"
                                               FontSize="8" HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <!-- Icerik + Filigran -->
                            <Grid Margin="30,36,30,26">
                                <!-- Filigran -->
                                <TextBlock Text="{Binding WatermarkText}"
                                           FontSize="{Binding WatermarkSize}"
                                           FontWeight="Black" Foreground="#CC0000"
                                           Opacity="{Binding WatermarkOpacity}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Panel.ZIndex="5"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="{Binding WatermarkAngle}"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <!-- Icerik satirlari -->
                                <StackPanel>
                                    <Rectangle Height="12" Fill="#C5C8D5" RadiusX="2" RadiusY="2"
                                               Width="160" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                                    <Rectangle Height="7" Fill="#E3E5EB" RadiusX="2" RadiusY="2" Margin="0,0,0,7"/>
                                    <Rectangle Height="7" Fill="#E3E5EB" RadiusX="2" RadiusY="2"
                                               Width="300" HorizontalAlignment="Left" Margin="0,0,0,7"/>
                                    <Rectangle Height="7" Fill="#E3E5EB" RadiusX="2" RadiusY="2" Margin="0,0,0,14"/>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="9"/>
                                            <RowDefinition Height="9"/>
                                        </Grid.RowDefinitions>
                                        <Rectangle Grid.Column="0" Grid.Row="0" Fill="#DDD" RadiusX="2" RadiusY="2" Margin="2"/>
                                        <Rectangle Grid.Column="1" Grid.Row="0" Fill="#DDD" RadiusX="2" RadiusY="2" Margin="2"/>
                                        <Rectangle Grid.Column="2" Grid.Row="0" Fill="#DDD" RadiusX="2" RadiusY="2" Margin="2"/>
                                        <Rectangle Grid.Column="0" Grid.Row="1" Fill="#EAEAEA" RadiusX="2" RadiusY="2" Margin="2"/>
                                        <Rectangle Grid.Column="1" Grid.Row="1" Fill="#EAEAEA" RadiusX="2" RadiusY="2" Margin="2"/>
                                        <Rectangle Grid.Column="2" Grid.Row="1" Fill="#EAEAEA" RadiusX="2" RadiusY="2" Margin="2"/>
                                        <Rectangle Grid.Column="0" Grid.Row="2" Fill="#EAEAEA" RadiusX="2" RadiusY="2" Margin="2"/>
                                        <Rectangle Grid.Column="1" Grid.Row="2" Fill="#EAEAEA" RadiusX="2" RadiusY="2" Margin="2"/>
                                        <Rectangle Grid.Column="2" Grid.Row="2" Fill="#EAEAEA" RadiusX="2" RadiusY="2" Margin="2"/>
                                    </Grid>
                                    <Rectangle Height="7" Fill="#E3E5EB" RadiusX="2" RadiusY="2" Margin="0,0,0,7"/>
                                    <Rectangle Height="7" Fill="#E3E5EB" RadiusX="2" RadiusY="2"
                                               Width="260" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Grid>
                            <!-- Alt bilgi -->
                            <Border Height="18" VerticalAlignment="Bottom" Background="#F2F2F5"
                                    CornerRadius="0,0,4,4" BorderBrush="#E0E0E5" BorderThickness="0,1,0,0">
                                <Grid Margin="12,0">
                                    <TextBlock Text="{Binding FooterLeft}" Foreground="#999"
                                               FontSize="7" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding FooterRight}" Foreground="#999"
                                               FontSize="7" HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </Grid>

            <!-- SAG PANEL -->
            <Border Grid.Column="2" Background="#0F1116" BorderBrush="#1AFFFFFF" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,14">

                        <!-- TARAYICI -->
                        <TextBlock Text="TARAYICI" Foreground="#444" FontSize="9"
                                   FontWeight="Bold" Margin="0,0,0,7"/>
                        <ComboBox ItemsSource="{Binding Scanners}"
                                  SelectedItem="{Binding SelectedScanner}"
                                  Background="#1A2030" Foreground="#DDE1EC"
                                  BorderBrush="#2F80ED" Padding="8,7" Margin="0,0,0,6"/>
                        <Button Content="Yenile" Command="{Binding FindScannersCommand}"
                                Background="#1E2030" Foreground="#8B91A4"
                                BorderThickness="1" BorderBrush="#2A2D38"
                                Padding="0,7" Margin="0,0,0,6" Cursor="Hand"/>
                        <Button Content="  Tarama Baslat  " Command="{Binding ScanCommand}"
                                Background="#2F80ED" Foreground="White" BorderThickness="0"
                                Padding="0,10" FontSize="13" FontWeight="SemiBold" Cursor="Hand"/>
                        <TextBlock Text="{Binding ScannerInfo}" Foreground="#F39C12"
                                   FontSize="11" TextWrapping="Wrap" Margin="0,7,0,0"/>

                        <Rectangle Height="1" Fill="#1AFFFFFF" Margin="0,12"/>

                        <!-- FORMAT / DPI -->
                        <TextBlock Text="CIKTI FORMATI" Foreground="#444" FontSize="9"
                                   FontWeight="Bold" Margin="0,0,0,7"/>
                        <ComboBox ItemsSource="{Binding Formats}"
                                  SelectedItem="{Binding SelectedFormat}"
                                  Background="#1A2030" Foreground="#DDE1EC"
                                  BorderBrush="#2A2D38" Padding="8,7" Margin="0,0,0,10"/>

                        <TextBlock Text="COZUNURLUK (DPI)" Foreground="#444" FontSize="9"
                                   FontWeight="Bold" Margin="0,0,0,7"/>
                        <ComboBox ItemsSource="{Binding DpiList}"
                                  SelectedItem="{Binding SelectedDpi}"
                                  Background="#1A2030" Foreground="#DDE1EC"
                                  BorderBrush="#2A2D38" Padding="8,7" Margin="0,0,0,10"/>

                        <TextBlock Text="RENK MODU" Foreground="#444" FontSize="9"
                                   FontWeight="Bold" Margin="0,0,0,7"/>
                        <ComboBox ItemsSource="{Binding ColorModes}"
                                  SelectedItem="{Binding SelectedColorMode}"
                                  Background="#1A2030" Foreground="#DDE1EC"
                                  BorderBrush="#2A2D38" Padding="8,7" Margin="0,0,0,10"/>

                        <Rectangle Height="1" Fill="#1AFFFFFF" Margin="0,4,0,12"/>

                        <!-- UST/ALT BILGI -->
                        <TextBlock Text="UST BILGI" Foreground="#444" FontSize="9"
                                   FontWeight="Bold" Margin="0,0,0,7"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding HeaderLeft, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#1A2030" Foreground="#DDE1EC" BorderBrush="#2A2D38"
                                     Padding="5,5" Margin="0,0,3,0" FontSize="11"/>
                            <TextBox Grid.Column="1" Text="{Binding HeaderCenter, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#1A2030" Foreground="#DDE1EC" BorderBrush="#2A2D38"
                                     Padding="5,5" Margin="0,0,3,0" FontSize="11"/>
                            <TextBox Grid.Column="2" Text="{Binding HeaderRight, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#1A2030" Foreground="#DDE1EC" BorderBrush="#2A2D38"
                                     Padding="5,5" FontSize="11"/>
                        </Grid>

                        <TextBlock Text="ALT BILGI" Foreground="#444" FontSize="9"
                                   FontWeight="Bold" Margin="0,0,0,7"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding FooterLeft, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#1A2030" Foreground="#DDE1EC" BorderBrush="#2A2D38"
                                     Padding="5,5" Margin="0,0,3,0" FontSize="11"/>
                            <TextBox Grid.Column="1" Text="{Binding FooterRight, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#1A2030" Foreground="#DDE1EC" BorderBrush="#2A2D38"
                                     Padding="5,5" FontSize="11"/>
                        </Grid>

                        <Rectangle Height="1" Fill="#1AFFFFFF" Margin="0,4,0,12"/>

                        <!-- FILIGRAN -->
                        <TextBlock Text="FILIGRAN" Foreground="#444" FontSize="9"
                                   FontWeight="Bold" Margin="0,0,0,7"/>
                        <TextBox Text="{Binding WatermarkText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#1A2030" Foreground="#DDE1EC" BorderBrush="#2A2D38"
                                 Padding="8,7" Margin="0,0,0,8" FontSize="13"/>

                        <TextBlock Text="Font" Foreground="#8B91A4" FontSize="10" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding SystemFonts}"
                                  SelectedItem="{Binding SelectedFont}"
                                  Background="#1A2030" Foreground="#DDE1EC"
                                  BorderBrush="#2A2D38" Padding="8,6" Margin="0,0,0,8"/>

                        <TextBlock Text="Boyut" Foreground="#8B91A4" FontSize="10" Margin="0,0,0,4"/>
                        <Slider Minimum="20" Maximum="100" Value="{Binding WatermarkSize}"
                                Foreground="#2F80ED" Margin="0,0,0,8"/>

                        <TextBlock Text="Opaklik" Foreground="#8B91A4" FontSize="10" Margin="0,0,0,4"/>
                        <Slider Minimum="0.03" Maximum="0.5" Value="{Binding WatermarkOpacity}"
                                Foreground="#2F80ED" Margin="0,0,0,8"/>

                        <TextBlock Text="Aci" Foreground="#8B91A4" FontSize="10" Margin="0,0,0,4"/>
                        <Slider Minimum="-90" Maximum="0" Value="{Binding WatermarkAngle}"
                                Foreground="#2F80ED" Margin="0,0,0,12"/>

                        <Rectangle Height="1" Fill="#1AFFFFFF" Margin="0,0,0,12"/>

                        <!-- IS AKISI -->
                        <TextBlock Text="IS AKISI" Foreground="#444" FontSize="9"
                                   FontWeight="Bold" Margin="0,0,0,7"/>
                        <ItemsControl ItemsSource="{Binding Steps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0AFFFFFF" BorderBrush="#0EFFFFFF"
                                            BorderThickness="1" CornerRadius="6"
                                            Padding="10,6" Margin="0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Icon}" Foreground="{Binding Color}"
                                                       FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       Foreground="#8B91A4" FontSize="11.5"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Status}"
                                                       Foreground="{Binding Color}" FontSize="10"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Background="#090A0D" BorderBrush="#1AFFFFFF" BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="#27AE60" Margin="0,0,6,0"/>
                    <TextBlock Text="Cevrimdisi - Veri Saklanmiyor"
                               Foreground="#27AE60" FontSize="10.5"/>
                    <TextBlock Text="   |   " Foreground="#333" FontSize="10.5"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#8B91A4" FontSize="10.5"/>
                </StackPanel>
                <TextBlock Text="{Binding CurrentTime}" HorizontalAlignment="Right"
                           VerticalAlignment="Center" Foreground="#444" FontSize="10.5"/>
            </Grid>
        </Border>
    </Grid>
</Window>
